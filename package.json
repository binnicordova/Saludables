{
    "name": "saludables",
    "main": "expo-router/entry",
    "version": "0.0.21",
    "scripts": {
        "start": "expo start",
        "mocks": "node ./scripts/mock-list-details.js",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "test": "jest --watchAll",
        "lint": "npx @biomejs/biome check",
        "format": "npx @biomejs/biome format --write",
        "build:dev": "eas build --platform all --profile development",
        "build:preview": "eas build --platform all --profile preview",
        "build:prod": "eas build --platform all --profile production",
        "build:prod:android": "eas build --platform android --profile production",
        "update:dev": "eas update --branch development --message \"Development update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:preview": "eas update --branch preview --message \"Preview update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:prod": "eas update --branch production --message \"Production update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:prod:android": "eas update --branch production --message \"Production update - $(date '+%Y-%m-%d %H:%M')\" --platform android",
        "eas-preview": "eas build --platform android --profile preview",
        "types": "tsc --noEmit --skipLibCheck",
        "wsp:send": "node ./scripts/send-wsp-message.js"
    },
    "jest": {
        "preset": "jest-expo"
    },
    "dependencies": {
        "@expo/ui": "0.2.0-canary-20260105-6b962e6",
        "@expo/vector-icons": "^15.0.3",
        "@lottiefiles/dotlottie-react": "^0.17.15",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-segmented-control/segmented-control": "2.5.7",
        "@react-navigation/bottom-tabs": "^7.2.0",
        "@react-navigation/native": "^7.0.14",
        "@shopify/flash-list": "2.0.2",
        "expo": "55.0.0-canary-20260105-6b962e6",
        "expo-asset": "12.0.13-canary-20260105-6b962e6",
        "expo-blur": "16.0.0-canary-20260105-6b962e6",
