{
    "name": "saludables",
    "main": "expo-router/entry",
    "version": "0.0.22",
    "scripts": {
        "start": "expo start",
        "mocks": "node ./scripts/mock-list-details.js",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "test": "jest --watchAll",
        "lint": "npx @biomejs/biome check",
        "format": "npx @biomejs/biome format --write",
        "build:dev": "eas build --platform all --profile development",
        "build:preview": "eas build --platform all --profile preview",
        "build:prod": "eas build --platform all --profile production",
        "build:prod:android": "eas build --platform android --profile production",
        "update:dev": "eas update --branch development --message \"Development update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:preview": "eas update --branch preview --message \"Preview update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:prod": "eas update --branch production --message \"Production update - $(date '+%Y-%m-%d %H:%M')\"",
        "update:prod:android": "eas update --branch production --message \"Production update - $(date '+%Y-%m-%d %H:%M')\" --platform android",
        "eas-preview": "eas build --platform android --profile preview",
        "types": "tsc --noEmit --skipLibCheck",
        "wsp:send": "node ./scripts/send-wsp-message.js"
    },
    "jest": {
        "preset": "jest-expo"
    },
    "dependencies": {
        "@expo/ui": "~57.0.7",
        "@expo/vector-icons": "^15.0.3",
        "@lottiefiles/dotlottie-react": "^0.17.15",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-segmented-control/segmented-control": "2.5.7",
        "@react-navigation/bottom-tabs": "^7.2.0",
        "@react-navigation/native": "^7.0.14",
        "@shopify/flash-list": "2.0.2",
        "expo": "^57.0.7",
        "expo-asset": "~57.0.6",
        "expo-blur": "~57.0.2",
        "expo-checkbox": "~57.0.0",
        "expo-clipboard": "~57.0.1",
        "expo-constants": "~57.0.6",
        "expo-file-system": "~57.0.1",
        "expo-font": "~57.0.1",
        "expo-haptics": "~57.0.1",
        "expo-image": "~57.0.1",
        "expo-linear-gradient": "~57.0.1",
        "expo-linking": "~57.0.3",
        "expo-localization": "~57.0.1",
        "expo-location": "~57.0.5",
        "expo-router": "~57.0.7",
        "expo-sharing": "~57.0.6",
        "expo-splash-screen": "~57.0.4",
        "expo-status-bar": "~57.0.1",
        "expo-symbols": "~57.0.1",
        "expo-system-ui": "~57.0.1",
        "expo-updates": "~57.0.8",
        "expo-web-browser": "~57.0.1",
        "jotai": "^2.3.0",
        "lottie-react-native": "~7.3.8",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-native": "0.86.0",
        "react-native-gesture-handler": "~2.32.0",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-web": "^0.21.0",
        "react-native-webview": "13.16.1"
    },
    "dependenciesMeta": {
        "jotai": {
            "optional": false
        }
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@biomejs/biome": "1.9.4",
        "@expo/config-types": "^54.0.8",
        "@expo/metro-runtime": "~57.0.6",
        "@types/jest": "^29.5.12",
        "@types/react": "~19.2.4",
        "@types/react-test-renderer": "^18.3.0",
        "dotenv": "^17.2.3",
        "jest": "^29.2.1",
        "jest-expo": "~57.0.2",
        "puppeteer": "^24.40.0",
        "qrcode-terminal": "^0.12.0",
        "react-test-renderer": "19.1.0",
        "sharp": "^0.34.4",
        "typescript": "~6.0.3",
        "whatsapp-web.js": "^1.34.6"
    },
    "private": true
}
